{
  "kind": "collectionType",
  "collectionName": "card_categories",
  "info": {
    "singularName": "card-category",
    "pluralName": "card-categories",
    "displayName": "CardCategory"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "popularText": {
      "type": "string"
    },
    "sub_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::sub-category.sub-category",
      "inversedBy": "card_categories"
    }
  }
}
